# TestBoard backend configuration
#
# Copy this file to `.env` and fill in the values you need, then export them
# into your shell / process manager before starting the backend. Note: this
# app reads plain environment variables via os.getenv() — it does NOT load
# .env files automatically (no python-dotenv dependency). Either:
#   - export them yourself (`set -a && source .env && set +a` on bash,
#     or load via your deploy platform's env var settings), or
#   - add python-dotenv and call load_dotenv() in backend/main.py if you'd
#     like automatic loading during local development.
#
# Every variable below is optional and has a safe default (or disables the
# related feature when unset) — the app runs with zero config out of the box.


# ==================== CORE / AUTH ====================

# Secret key used to sign JWT access tokens. Required in production
# (TESTBOARD_ENV=production); falls back to an insecure dev-only default
# otherwise. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
TESTBOARD_SECRET_KEY=

# development | production. Enforces TESTBOARD_SECRET_KEY being set when "production".
TESTBOARD_ENV=development

# Comma-separated list of origins allowed to call the API (CORS).
TESTBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Base URL of the deployed frontend, used to build absolute links in
# notification emails (e.g. "Open TestBoard: https://your-app.com/#admin").
# Leave unset in local dev; links are simply omitted from emails.
TESTBOARD_APP_URL=


# ==================== ATTACHMENT STORAGE ====================
# Screenshots and project documents (BRDs, reports, etc.)

# local (default) | gdrive
TESTBOARD_STORAGE_BACKEND=local

# --- local backend ---
# Directory attachments are written to and served from (via /uploads).
# Point this at a persistent volume in production — container filesystems
# are often ephemeral and will lose files on redeploy/restart otherwise.
TESTBOARD_STORAGE_DIR=

# --- gdrive backend ---
# ID of the shared Drive folder to upload into (the long string in the
# folder's URL). Share the folder with your service account's email as Editor.
TESTBOARD_GDRIVE_FOLDER_ID=

# Service account credentials — provide ONE of these two:
# Path to the downloaded service-account JSON key file:
TESTBOARD_GDRIVE_CREDENTIALS_FILE=
# ...or the JSON key content inline (useful on platforms that only support
# string env vars, not file mounts):
TESTBOARD_GDRIVE_CREDENTIALS_JSON=


# ==================== EMAIL (SMTP) ====================
# Powers email notifications (access requests, approvals, bug assignments).
# Unset TESTBOARD_SMTP_HOST = email disabled; in-app notifications still work.

TESTBOARD_SMTP_HOST=
TESTBOARD_SMTP_PORT=587
TESTBOARD_SMTP_USER=
TESTBOARD_SMTP_PASSWORD=
# Defaults to TESTBOARD_SMTP_USER if unset.
TESTBOARD_SMTP_FROM=
# Set to "false" to disable STARTTLS.
TESTBOARD_SMTP_USE_TLS=true

# --- Example: Gmail (use an App Password, not your real password) ---
# TESTBOARD_SMTP_HOST=smtp.gmail.com
# TESTBOARD_SMTP_PORT=587
# TESTBOARD_SMTP_USER=youraddress@gmail.com
# TESTBOARD_SMTP_PASSWORD=your-16-char-app-password

# --- Example: Outlook / Office365 ---
# TESTBOARD_SMTP_HOST=smtp.office365.com
# TESTBOARD_SMTP_PORT=587
# TESTBOARD_SMTP_USER=youraddress@outlook.com
# TESTBOARD_SMTP_PASSWORD=your-password
